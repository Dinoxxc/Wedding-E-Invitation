# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=wedding_invitation
DB_PORT=3306

# Admin Credentials (for admin panel access)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# JWT Secret (for admin authentication)
JWT_SECRET=your_secret_key_here_change_this_in_production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Wedding Details (optional - can be configured in frontend)
WEDDING_DATE=2026-12-31T18:00:00

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM_NAME=Wedding Invitation

# Twilio SMS Configuration (optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Photo Upload Settings
AUTO_APPROVE_PHOTOS=true
